{
  "name": "@spanoai/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SpanoAI core engine — Context Store, Message Bus, Audit Log",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:migrate": "bun run src/db/migrate.ts",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "hono": "^4",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
