{
  "name": "@spanoai/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Model Context Protocol server for SpanoAI — exposes the shared-memory context store and message bus as MCP tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sathwik-git/spanoai.git",
    "directory": "packages/mcp"
  },
  "keywords": ["mcp", "model-context-protocol", "spanoai", "agents", "memory", "claude", "adk"],
  "bin": {
    "spanoai-mcp": "./dist/stdio.js",
    "spanoai-mcp-http": "./dist/http-server.js"
  },
  "module": "src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "start": "bun run src/stdio.ts",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@spanoai/sdk": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.0"
  }
}
