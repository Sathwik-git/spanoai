# .env.example — copy to .env and adjust. Never commit .env.
# These defaults match docker-compose.yml so `docker compose up -d` + these
# values Just Work for local development of the core engine.

# ── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ── Redis (matches docker-compose.yml) ────────────────────────────────
REDIS_URL=redis://:spanoaidev@localhost:6379

# ── Postgres (matches docker-compose.yml) ─────────────────────────────
DATABASE_URL=postgresql://spanoai:spanoaidev@localhost:5432/spanoai

# Semantic-search embedder for the served engine:
#   hash — deterministic, dependency-free (default; no external API)
#   none — disable semantic search (search returns [])
SPANOAI_EMBEDDER=hash

# ── Engine tuning (optional — sane defaults applied if unset) ─────────
# Idempotency record retention (seconds). Spec default: max(session TTL, 24h).
SPANOAI_OPS_TTL_SECONDS=86400
# How long a claimed-but-unacked message may sit before the sweeper reclaims it.
SPANOAI_VISIBILITY_TIMEOUT_MS=30000
# WebSocket replay buffer size (events) and TTL (seconds).
SPANOAI_WS_BUFFER_SIZE=100
SPANOAI_WS_BUFFER_TTL_SECONDS=300

# ── Object storage for artifacts (matches docker-compose MinIO) ───────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=spanoai-artifacts
S3_REGION=us-east-1

# Claim-check threshold: max bytes for an INLINE value/payload (Redis).
# Bigger than this must be uploaded as an artifact. 256 KB default.
SPANOAI_MAX_INLINE_BYTES=262144
# Artifact (file) soft cap in bytes. 0 = unlimited (cost/abuse lever only).
SPANOAI_MAX_ARTIFACT_BYTES=0
# Presigned URL lifetimes (seconds).
SPANOAI_ARTIFACT_UPLOAD_TTL_SECONDS=900
SPANOAI_ARTIFACT_DOWNLOAD_TTL_SECONDS=300
# Verify sha256 by streaming the object back when size <= this (bytes).
SPANOAI_ARTIFACT_HASH_VERIFY_MAX_BYTES=67108864
