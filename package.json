{
  "name": "spanoai",
  "version": "0.1.0",
  "private": true,
  "description": "SpanoAI — shared working memory for multi-agent AI systems",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "bun run --filter=@spanoai/server db:migrate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "turbo": "^2.9.18",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
